Testing/
.cache/

# OS files (macOS)
.DS_Store
._*
.AppleDouble

# IDE / local tooling (not for public repo)
.vscode/
.idea/
.cursor/
AGENTS.md

# Local & generated datasets: everything under data/ is downloaded or produced by the
# apps/scripts and stays local. Allow-list only what we intend to commit — e.g. a README
# or a committed JSON benchmark baseline under data/benchmark/.
data/*
!data/README.md
!data/benchmark/
data/benchmark/*
!data/benchmark/*.json

# ROS workspace (colcon workspace; regenerated by scripts/build_ros.sh)
ros/ws/
